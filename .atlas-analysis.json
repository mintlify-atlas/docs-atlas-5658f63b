  "keyFeatures": [
    "Browse all League of Legends champions with detailed information",
    "View champion skins and chromas with high-quality images",
    "Track current sale rotation for champions and skins",
    "Search and filter game assets (icons, emotes, items)",
    "Look up player profiles by Riot ID with rank and mastery",
    "Admin panel for managing streamers",
    "Blog posts with League of Legends news and guides",
    "Integration with Riot Games API and Meraki Analytics"
  ],
  "publicApiSurface": [
    "ChampionController::index() - List all champions",
    "ChampionController::show() - Show champion details",
    "ChampionSkinController::index() - List all skins",
    "ChampionSkinController::show() - Show skin details",
    "SaleController::index() - Show current sales rotation",
    "SummonerIconController::index() - List all summoner icons",
    "SummonerEmoteController::index() - List all emotes",
    "AssetsController::index() - Browse game assets",
    "BorisStaticDataClient::getChampions() - Fetch champion data",
    "BorisStaticDataClient::getChampionRates() - Fetch champion rates"
  ]
